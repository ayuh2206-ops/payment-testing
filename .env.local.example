# ══════════════════════════════════════════════════════════════
#  RAZORPAY KEYS  —  https://dashboard.razorpay.com/app/keys
#  Copy these exact variable names into Vercel → Settings → Environment Variables
# ══════════════════════════════════════════════════════════════

# Server-side secret (NEVER expose this to the browser)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Webhook secret — Razorpay Dashboard → Settings → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Exposed to browser (only the key ID, never the secret)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
